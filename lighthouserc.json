{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:8080"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromePath": "/usr/bin/chromium-browser",
        "onlyCategories": [
          "performance",
          "accessibility",
          "best-practices",
          "seo"
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "performance": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "best-practices": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "seo": [
          "error",
          {
            "minScore": 0.9
          }
        ],
        "cumululative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "first-contentful-paint": [
          "error",
          {
            "maxNumericValue": 1800
          }
        ],
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 2500
          }
        ]
      }
    }
  }
}
